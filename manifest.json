{
  "manifest_version": 3,
  "name": "Add to Toodledo",
  "version": "2.2.0",
  "description": "現在のタブのタイトル・URL・選択テキストからToodledoにタスクを追加します。API連携版。",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications",
    "identity"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Add to Toodledo"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
